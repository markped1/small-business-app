<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ── Staff Header Bar ── -->
    <LinearLayout
        android:id="@+id/staffHeaderBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Business name + today's stats -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStaffBusinessName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Business"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today: "
                        android:textColor="#CCffffff"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvTodayTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₦0.00"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  •  "
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvTodayTransactions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 sales today"
                        android:textColor="#CCffffff"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Daily Report toggle button -->
            <Button
                android:id="@+id/btnDailyReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Daily Report"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:backgroundTint="@color/white"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                style="@style/Widget.MaterialComponents.Button"
                app:cornerRadius="16dp"
                android:layout_marginEnd="6dp" />

            <!-- Cart badge -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:tint="@color/white"
                    android:contentDescription="Cart" />

                <TextView
                    android:id="@+id/tvStaffCartBadge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:background="@color/accent"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Logout -->
            <Button
                android:id="@+id/btnStaffLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:backgroundTint="@color/white"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                style="@style/Widget.MaterialComponents.Button"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Content area (below header) ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="68dp">

        <!-- ════════════════════════════════════════════ -->
        <!-- SELL MODE (default)                         -->
        <!-- ════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutSellMode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Products Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.4"
                android:orientation="vertical"
                android:background="@color/background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Products"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:paddingStart="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp" />

                <TextView
                    android:id="@+id/tvStaffNoProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_products"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStaffProducts"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="8dp"
                    android:clipToPadding="false" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/grey_300" />

            <!-- Cart Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/white">

                <!-- Cart Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🛒 Current Order"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btnStaffClearCart"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="Clear"
                        android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/red_400" />
                </LinearLayout>

                <!-- Empty cart -->
                <LinearLayout
                    android:id="@+id/layoutStaffCartEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cart_empty"
                        android:textColor="@color/text_hint"
                        android:textSize="13sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Cart items -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStaffCart"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:visibility="gone"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:clipToPadding="false" />

                <!-- Cart Footer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/white"
                    android:elevation="4dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvStaffCartTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₦0.00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnStaffCheckout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Confirm Sale"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_checkout_button"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:enabled="false" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ════════════════════════════════════════════ -->
        <!-- DAILY REPORT MODE                           -->
        <!-- Revenue + transactions only — NO profit     -->
        <!-- ════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/layoutReportMode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Report date header -->
                <TextView
                    android:id="@+id/tvReportDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Report — 01 Jan 2026"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:paddingBottom="12dp" />

                <!-- Summary card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Green header strip -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_report_header_daily"
                            android:padding="12dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="📊 Today's Summary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/tvReportTxCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 transactions"
                                android:textSize="12sp"
                                android:textColor="#CCffffff" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="14dp">

                            <!-- Total Revenue -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Revenue"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvReportTotalRevenue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₦0.00"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary" />
                            </LinearLayout>

                            <!-- Items Sold -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Items Sold"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvReportItemsSold"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 items"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Products sold breakdown -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRODUCTS SOLD TODAY"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.08"
                            android:paddingBottom="10dp" />

                        <TextView
                            android:id="@+id/tvProductBreakdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sales yet"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:lineSpacingMultiplier="1.6" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Transaction list -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALL TRANSACTIONS TODAY"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.08"
                            android:paddingBottom="10dp" />

                        <TextView
                            android:id="@+id/tvTransactionList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No transactions yet"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:lineSpacingMultiplier="1.5"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- Sale Success Overlay -->
    <FrameLayout
        android:id="@+id/layoutStaffSaleSuccess"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:gravity="center"
        android:visibility="gone"
        android:alpha="0">

        <LinearLayout
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_success_overlay"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_check_circle"
                android:contentDescription="Success" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Sale Recorded!"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
