<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- HEADER — clean single line, no crowding                   -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:elevation="4dp">

        <!-- Business info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPosBusinessName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Business"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPosAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textColor="#CCffffff"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Cart badge -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="@color/white"
                android:contentDescription="Cart" />

            <TextView
                android:id="@+id/tvPosCartBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:background="@color/accent"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- TODAY'S STATS BAR — tabulated summary                     -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_light"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Today's Revenue -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Sales"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvPosTodayTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₦0.00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/grey_300" />

        <!-- Transaction count -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transactions"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvPosTodayCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/grey_300" />

        <!-- Cart total -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Order"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvPosCartTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₦0.00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- MAIN CONTENT — toggles between SELL and REPORT            -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ─────────────────────────────────────────────────── -->
        <!-- SELL MODE                                           -->
        <!-- ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutPosSellMode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Search bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/white"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="16sp"
                    android:paddingEnd="8dp" />

                <EditText
                    android:id="@+id/etPosSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search products…"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:inputType="text"
                    android:singleLine="true"
                    android:imeOptions="actionSearch" />
            </LinearLayout>

            <!-- Products list (top half) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.2"
                android:orientation="vertical"
                android:background="@color/background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available Products"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:paddingStart="14dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tvPosNoProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No products available. Ask admin to add products."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPosProducts"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:clipToPadding="false" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/grey_300" />

            <!-- Current Order (bottom half) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/white">

                <!-- Order header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/grey_100"
                    android:paddingStart="14dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🛒  Current Order"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Clear button — white background so it's always visible -->
                    <Button
                        android:id="@+id/btnPosClearCart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        android:textSize="12sp"
                        android:textColor="@color/red_400"
                        android:backgroundTint="@color/white"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/red_400"
                        app:cornerRadius="8dp" />
                </LinearLayout>

                <!-- Column headers for cart table -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="@color/grey_50">

                    <TextView android:layout_width="44dp" android:layout_height="wrap_content" android:text="" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Item" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_secondary" android:paddingStart="10dp" />
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="Qty" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_secondary" android:gravity="center" />
                    <TextView android:layout_width="68dp" android:layout_height="wrap_content" android:text="Amount" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_secondary" android:gravity="end" />
                    <TextView android:layout_width="26dp" android:layout_height="wrap_content" android:text="" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/grey_200" />

                <!-- Empty cart -->
                <LinearLayout
                    android:id="@+id/layoutPosCartEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cart is empty. Tap a product to add it."
                        android:textColor="@color/text_hint"
                        android:textSize="13sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Cart items -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPosCart"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:visibility="gone"
                    android:clipToPadding="false" />

                <!-- Order footer: total + confirm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/white"
                    android:elevation="4dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ORDER TOTAL"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.08" />

                        <!-- Cart total shown here too (synced with stats bar) -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvPosOrderTotalFooter"
                            android:text="₦0.00"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnPosCheckout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Confirm Sale"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_checkout_button"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:enabled="false" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ─────────────────────────────────────────────────── -->
        <!-- DAILY REPORT MODE                                   -->
        <!-- ─────────────────────────────────────────────────── -->
        <ScrollView
            android:id="@+id/layoutPosReportMode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvPosReportDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Report"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:paddingBottom="10dp" />

                <!-- Summary stats card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_report_header_daily"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📊  Today's Summary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/white" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Revenue" android:textSize="11sp" android:textColor="@color/text_secondary" />
                                <TextView android:id="@+id/tvPosReportRevenue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₦0.00" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/primary" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transactions" android:textSize="11sp" android:textColor="@color/text_secondary" />
                                <TextView android:id="@+id/tvPosReportTxCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Items Sold" android:textSize="11sp" android:textColor="@color/text_secondary" />
                                <TextView android:id="@+id/tvPosReportItemsSold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Products sold table -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRODUCTS SOLD"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.08"
                            android:paddingBottom="8dp" />

                        <TextView
                            android:id="@+id/tvPosProductTable"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sales yet"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="monospace"
                            android:lineSpacingMultiplier="1.5" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Transaction log -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRANSACTION LOG"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.08"
                            android:paddingBottom="8dp" />

                        <TextView
                            android:id="@+id/tvPosTxLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No transactions yet"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="monospace"
                            android:lineSpacingMultiplier="1.5" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Clock-out info -->
                <TextView
                    android:id="@+id/tvPosClockOutInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingBottom="8dp"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

        <!-- Sale success overlay -->
        <FrameLayout
            android:id="@+id/layoutPosSaleSuccess"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#88000000"
            android:gravity="center"
            android:visibility="gone"
            android:alpha="0">

            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_success_overlay"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="Success" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Sale Recorded!"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

    </FrameLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- BOTTOM ACTION BAR — Report | Clock Out | Logout           -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/btnBottomReport"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="📋 Report"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary"
            app:cornerRadius="8dp" />

        <Button
            android:id="@+id/btnBottomClockOut"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="⏱ Clock Out"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/orange_500"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="8dp" />

        <Button
            android:id="@+id/btnBottomLogout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="← Logout"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />
    </LinearLayout>

</LinearLayout>
