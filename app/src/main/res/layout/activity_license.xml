<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo + Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_launcher"
                android:contentDescription="ToMega POS" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ToMega POS"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <!-- Status badge -->
            <TextView
                android:id="@+id/tvLicenseStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="⏳ Free Trial"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/orange_500" />

            <TextView
                android:id="@+id/tvLicenseMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="You have 3 days remaining in your free trial."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />
        </LinearLayout>

        <!-- Continue trial button -->
        <Button
            android:id="@+id/btnContinueTrial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Continue Trial (3 days left)"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="visible"
            style="@style/PrimaryButton" />

        <!-- Activation Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardActivation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Activate License"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter the business name and license key provided by ToMega."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:paddingBottom="4dp" />

                <!-- Key type hint -->
                <TextView
                    android:id="@+id/tvKeyTypeHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@color/primary_light"
                    android:padding="10dp"
                    android:text="Single key: TMPOS-XXXX-XXXX-XXXX-XXXX\nBatch key:   TMBAT-XXXX-NNN-XX\n(Batch keys require internet to verify seats)"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:visibility="gone" />

                <!-- Business name field -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Business Name (exactly as registered)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLicenseBusinessName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- License key field -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="License Key  (TMPOS-XXXX-XXXX-XXXX-XXXX)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLicenseKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:fontFamily="monospace"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Paste button -->
                <Button
                    android:id="@+id/btnPasteKey"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="📋 Paste from Clipboard"
                    android:textSize="12sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/primary" />

                <ProgressBar
                    android:id="@+id/progressActivation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnActivate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="🔑  Activate Now"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    style="@style/PrimaryButton" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- How to get a key -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How to get a license key"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:paddingBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Contact ToMega to purchase a license.\nProvide your exact business name and you will receive a key in the format:\n\nTMPOS-XXXX-XXXX-XXXX-XXXX\n\nEach key is tied to one business name."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="ToMega POS v1.0  •  © 2026 ToMega"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
