<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Product thumbnail -->
    <ImageView
        android:id="@+id/ivCartItem"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_product_placeholder"
        android:contentDescription="Product"
        android:background="@color/grey_100" />

    <!-- Name + price -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tvCartItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Item Name"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvCartItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₦0.00"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Quantity controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Decrease button -->
        <Button
            android:id="@+id/btnDecrease"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="−"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_qty_button"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:contentDescription="Decrease quantity" />

        <TextView
            android:id="@+id/tvCartItemQty"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <!-- Increase button -->
        <Button
            android:id="@+id/btnIncrease"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="+"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_qty_button"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:contentDescription="Increase quantity" />
    </LinearLayout>

    <!-- Subtotal -->
    <TextView
        android:id="@+id/tvCartItemSubtotal"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="₦0.00"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:gravity="end"
        android:paddingStart="4dp" />

    <!-- Remove button -->
    <Button
        android:id="@+id/btnRemoveItem"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="✕"
        android:textSize="11sp"
        android:textColor="@color/red_400"
        android:background="@android:color/transparent"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:contentDescription="Remove item" />

</LinearLayout>
