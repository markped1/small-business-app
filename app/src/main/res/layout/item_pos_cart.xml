<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@color/white">

    <!-- Product thumbnail -->
    <ImageView
        android:id="@+id/ivCartPosItem"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_product_placeholder"
        android:background="@color/grey_100"
        android:contentDescription="Product" />

    <!-- Name + time -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tvCartPosName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Item Name"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCartPosPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="₦0.00"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvCartPosTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00"
                android:textSize="10sp"
                android:textColor="@color/text_hint" />
        </LinearLayout>
    </LinearLayout>

    <!-- Qty controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnCartPosDecrease"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="−"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_qty_button"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:contentDescription="Decrease" />

        <TextView
            android:id="@+id/tvCartPosQty"
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <Button
            android:id="@+id/btnCartPosIncrease"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="+"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_qty_button"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:contentDescription="Increase" />
    </LinearLayout>

    <!-- Subtotal -->
    <TextView
        android:id="@+id/tvCartPosSubtotal"
        android:layout_width="68dp"
        android:layout_height="wrap_content"
        android:text="₦0.00"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:gravity="end"
        android:paddingStart="4dp" />

    <!-- Remove -->
    <Button
        android:id="@+id/btnCartPosRemove"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:text="✕"
        android:textSize="10sp"
        android:textColor="@color/red_400"
        android:background="@android:color/transparent"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:contentDescription="Remove" />

</LinearLayout>
