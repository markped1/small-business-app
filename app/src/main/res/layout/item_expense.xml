<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="10dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Left accent bar -->
        <View
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:background="@color/red_400"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExpenseDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Expense Description"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvExpenseCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Category"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvExpenseDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01 Jan 2024"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvExpenseAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₦0.00"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/red_400"
            android:paddingStart="8dp"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/btnEditExpense"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="✏"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:contentDescription="Edit" />

        <Button
            android:id="@+id/btnDeleteExpense"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="🗑"
            android:textSize="12sp"
            android:textColor="@color/red_400"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:contentDescription="Delete" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
